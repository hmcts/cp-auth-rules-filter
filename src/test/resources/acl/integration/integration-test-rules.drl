package acl.integration

import uk.gov.moj.cpp.authz.drools.Action;
import uk.gov.moj.cpp.authz.drools.Outcome;

global uk.gov.moj.cpp.authz.http.providers.UserAndGroupProvider userAndGroupProvider;

rule "Allow vendor-supplied sjp.delete-financial-means for Legal Advisers"
when
    $o: Outcome()
    $a: Action(name == "sjp.delete-financial-means")
    eval(userAndGroupProvider.isMemberOfAnyOfTheSuppliedGroups($a, "Legal Advisers"))
then
    $o.setSuccess(true);
end

rule "Allow header-supplied allowed-explicit-action for Legal Advisers"
when
    $o: Outcome()
    $a: Action(name == "allowed-explicit-action")
    eval(userAndGroupProvider.isMemberOfAnyOfTheSuppliedGroups($a, "Legal Advisers"))
then
    $o.setSuccess(true);
end

rule "Allow fallback GET /api/resource for Legal Advisers"
when
    $o: Outcome()
    $a: Action(name == "GET /api/resource")
    eval(userAndGroupProvider.isMemberOfAnyOfTheSuppliedGroups($a, "Legal Advisers"))
then
    $o.setSuccess(true);
end
